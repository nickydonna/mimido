/* Write your global styles here, in PostCSS syntax */
@tailwind base;
@tailwind components;
@tailwind utilities;

.milkdown {
	@apply bg-slate-50 px-2 py-2 my-5 border rounded;
}

.milkdown ul {
	list-style: disc;
}

.milkdown ul li p {
	margin: 0 !important;
	margin-bottom: 5px;
}

.editor {
	@apply mx-auto;
}
